# Copie para .env e preencha com os dados do seu projeto Supabase
# (Project Settings → API). Pode usar qualquer um dos dois prefixos.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Compatibilidade com o app legado (mesmos valores):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PIN da rota /org (ADM). Não commitar valor real.
VITE_ADMIN_PIN=
VITE_ADMIN_PIN_SHA256=
